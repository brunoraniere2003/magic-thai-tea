# The Red Flying Dragon — environment variables (copy to .env.local; never commit secrets)

# Resend — contact form delivery (ADR 0010, spec 030). TEMPORARY: create a key at
# https://resend.com using the OWNER's email (brunoraniere2003@gmail.com); leads
# land in that inbox (free tier) marked [TEMPORARY] to forward to Ethan.
RESEND_API_KEY=

# Cloudflare Turnstile — anti-spam (constitution §10). https://dash.cloudflare.com (Turnstile)
# Public site key is exposed to the browser; the secret stays server-side.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
